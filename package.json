{
  "name": "dienstenlezer",
  "version": "1.3.3",
  "description": "Web- en desktopapp voor diensten-pdf's, omlopen en Qbuzz-livegegevens.",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "web:dev": "vite --host 127.0.0.1 --port 5173",
    "build": "tsc --noEmit && vite build",
    "web:build": "tsc --noEmit && vite build",
    "test": "vitest run",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "server:dev": "cargo run --manifest-path src-tauri/Cargo.toml --no-default-features --features server --bin dienstenlezer-server",
    "server:build": "cargo build --release --manifest-path src-tauri/Cargo.toml --no-default-features --features server --bin dienstenlezer-server",
    "deploy:build": "npm run web:build && npm run server:build",
    "ha:addon:package": "node scripts/package-ha-addon.mjs",
    "ha:addon:check": "node scripts/check-ha-addon.mjs",
    "ha:repository:sync": "node scripts/sync-ha-repository.mjs",
    "github:source:sync": "node scripts/sync-source-repository.mjs",
    "desktop:dev": "tauri dev",
    "release:clean": "node scripts/clean-installers.mjs",
    "desktop:build": "npm run release:clean && tauri build --bundles nsis",
    "exe": "npm run release:clean && tauri build --bundles nsis"
  },
  "keywords": [
    "diensten",
    "omlopen",
    "pdf",
    "vite",
    "react"
  ],
  "author": "",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "lucide-react": "^1.24.0",
    "pdfjs-dist": "^6.1.200",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
