{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DienstenLezer",
  "version": "1.3.2",
  "identifier": "nl.dienstenlezer.desktop",
  "build": {
    "beforeDevCommand": "npm run web:dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run web:build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DienstenLezer",
        "width": 1440,
        "height": 980,
        "minWidth": 1080,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"],
    "resources": []
  }
}
